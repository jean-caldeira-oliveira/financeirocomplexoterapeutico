# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o arquivo .env no repositório

# ─── Novo sistema de chaves do Supabase (recomendado) ───────────────────────
# Encontre em: Project Settings → API → "Publishable and secret API keys"

# URL do projeto (Project Settings → API → Project URL)
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# ID do projeto (parte inicial da URL, ex: "xyzabc123")
VITE_SUPABASE_PROJECT_ID="seu-project-id-aqui"

# Publishable key — segura para usar no browser (começa com "sb_publishable_")
# Encontre em: Project Settings → API → Publishable key
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# ─── ATENÇÃO: Secret key ─────────────────────────────────────────────────────
# A secret key (começa com "sb_secret_") NÃO deve ser usada no frontend.
# Use-a APENAS em servidores backend, Edge Functions ou scripts de CI/CD.
# As Edge Functions do Supabase recebem SUPABASE_SERVICE_ROLE_KEY automaticamente.
# NUNCA coloque a secret key neste arquivo ou no código frontend.
